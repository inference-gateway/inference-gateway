#!/bin/sh
#
# Pre-push hook: run go test and task lint before pushing.
#
# Configure the repository to use this directory:
#   git config core.hooksPath .githooks
#
# To skip these checks (emergency only):
#   git push --no-verify

set -e

echo "=== pre-push: running checks ==="

echo "  go test ./..."
go test -race -v ./...

echo "  task lint"
task lint

echo "=== pre-push checks passed ==="
